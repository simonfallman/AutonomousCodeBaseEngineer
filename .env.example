REPO_PATH=/path/to/target/repo

# AWS credentials for Amazon Bedrock (Titan Embeddings + Claude)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# LLM model for summarization/analysis (default: Claude Sonnet 4)
# BEDROCK_LLM_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251115-v1:0

# PostgreSQL with pgvector
DATABASE_URL=postgresql://user:password@localhost:5432/ace

# GitHub personal access token (repo scope) for opening PRs
GITHUB_TOKEN=
